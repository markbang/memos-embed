{
  "name": "@memos-embed/wc",
  "version": "0.4.0",
  "description": "Web Component wrapper for embedding Memos memo cards.",
  "type": "module",
  "homepage": "https://github.com/markbang/memos-embed/tree/main/packages/memos-embed-wc#readme",
  "bugs": {
    "url": "https://github.com/markbang/memos-embed/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markbang/memos-embed.git"
  },
  "keywords": [
    "memos",
    "embed",
    "web-components",
    "custom-elements"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/register.ts --format esm,cjs --dts --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "memos-embed": "workspace:*"
  }
}
